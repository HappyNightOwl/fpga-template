# Project-local FPGA workflow configuration.
# Copy this file into another project folder and edit only the values you need.

# Remote build server and Vivado setup.
# Need to be able to use `ssh FPGA` to access server . u may need public key(**change to ur own!**)
REMOTE_HOST=pku

# CHANGE IFF U R USING UR OWN SERVER
VIVADO_SETTINGS=/home/ubuntu/Xilinx/2025.2/Vivado/settings64.sh

# Remote build directory. Leave commented out to use /mnt/data/fpga/<folder-name>.
# CHANGE IFF U R USING UR OWN SERVER
REMOTE_PROJECT_DIR=/home/ubuntu/Vivado_Projects/remote-test

# FPGA build settings.
TOP_MODULE=top
FPGA_PART=xc7a35tfgg484-2
BITSTREAM_NAME=top.bit

# Local programmer command.
PROGRAMMER=openFPGALoader
PROGRAMMER_ARGS="--cable digilent_hs2"
